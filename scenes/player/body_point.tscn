[gd_scene format=3 uid="uid://der1yow75oll6"]

[ext_resource type="Texture2D" uid="uid://bv3u4r34afgkg" path="res://assets/white_circle.png" id="1_krwlc"]

[sub_resource type="GDScript" id="GDScript_0tsoq"]
resource_name = "point"
script/source = "extends Node2D

@export var neighbours: Array[Node2D] = []
@export var max_dist: float = 60.0
@export var min_dist: float = 30.0
@export var stiffness: float = 0.2
@export var is_extremity: bool = false

var dragging := false
var drag_offset := Vector2.ZERO


func _on_button_down():
	if $\"../..\".canMove:
		dragging = true
		drag_offset = global_position - get_global_mouse_position()

func _on_button_up():
	dragging = false

func _enter_tree() -> void:
	if is_extremity:
		$WhiteCircle.scale = Vector2(0.1,0.1)
		$WhiteCircle.self_modulate = Color(1,1,1,1)

func _process(_delta):
	if not $\"../..\".canMove:
		dragging = false
		
	if dragging:
		global_position = get_global_mouse_position() + drag_offset
		return
	
	for point in neighbours:
		var direction = global_position - point.global_position
		var distance = direction.length()
		
		if distance > max_dist:
			global_position -= direction.normalized() * (distance - max_dist) * stiffness
		
		if distance < min_dist and distance > 0:
			global_position += direction.normalized() * (min_dist - distance) * stiffness
"

